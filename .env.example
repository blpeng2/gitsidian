# Gitsidian Environment Variables
# Copy this file to .env.local for local development

# GitHub OAuth App Client ID (optional - enables OAuth login flow)
# Create an OAuth App at https://github.com/settings/applications/new
VITE_OAUTH_CLIENT_ID=

# GitHub Personal Access Token (optional - auto-login for personal deployments)
# Create a token at https://github.com/settings/tokens/new?scopes=repo,read:user
VITE_GITHUB_TOKEN=

# Custom base path for deployment (optional - defaults to /gitsidian/)
# Set to / for desktop builds
VITE_BASE_PATH=
